const ADMIN_PIN = '1234'

export default function AdminPinGate({ onSuccess }) {
  const [digits, setDigits] = useState(['', '', '', ''])
  const [shake, setShake] = useState(false)
  const [error, setError] = useState('')
  const [success, setSuccess] = useState(false)

  const refs = [useRef(null), useRef(null), useRef(null), useRef(null)]

  useEffect(() => {
    refs[0].current?.focus()
  }, [])

  const triggerShake = useCallback(() => {
    setShake(true)
    setError('รหัสไม่ถูกต้อง กรุณาลองใหม่')
    setTimeout(() => {
      setShake(false)
      setError('')
      setDigits(['', '', '', ''])
      refs[0].current?.focus()
    }, 600)
  }, [])

  const checkPin = useCallback((currentDigits) => {
    const pin = currentDigits.join('')
    if (pin === ADMIN_PIN) {
      setSuccess(true)
      setTimeout(() => onSuccess(), 300)
    } else {
      triggerShake()
    }
  }, [onSuccess, triggerShake])

  const handleChange = useCallback((idx, value) => {
    if (!/^\d?$/.test(value)) return

    const digit = value.slice(-1)
    const newDigits = [...digits]
    newDigits[idx] = digit
    setDigits(newDigits)

    if (digit && idx < 3) {
      refs[idx + 1].current?.focus()
    }

    if (digit && idx === 3) {
      const full = [...newDigits.slice(0, 3), digit]
      if (full.every(d => d !== '')) {
        checkPin(full)
      }
    }
  }, [digits, checkPin])

  const handleKeyDown = useCallback((idx, e) => {
    if (e.key === 'Backspace') {
      if (!digits[idx] && idx > 0) {
        const newDigits = [...digits]
        newDigits[idx - 1] = ''
        setDigits(newDigits)
        refs[idx - 1].current?.focus()
      } else {
        const newDigits = [...digits]
        newDigits[idx] = ''
        setDigits(newDigits)
      }
    } else if (e.key === 'ArrowLeft' && idx > 0) {
      refs[idx - 1].current?.focus()
    } else if (e.key === 'ArrowRight' && idx < 3) {
      refs[idx + 1].current?.focus()
    }
  }, [digits])

  const handlePaste = useCallback((e) => {
    e.preventDefault()
    const pasted = e.clipboardData.getData('text').replace(/\D/g, '').slice(0, 4)
    if (!pasted) return
    const newDigits = ['', '', '', '']
    for (let i = 0; i < pasted.length; i++) {
      newDigits[i] = pasted[i]
    }
    setDigits(newDigits)
    const focusIdx = Math.min(pasted.length, 3)
    refs[focusIdx].current?.focus()
    if (pasted.length === 4) {
      checkPin(newDigits)
    }
  }, [checkPin])

  return (
    <div
      className="min-h-[70vh] flex items-center justify-center px-4"
    >
      <div
        className="card w-full max-w-sm p-8 flex flex-col items-center gap-6"
        style={{ animation: 'slideUp 0.3s ease' }}
      >
        {/* Icon + Title */}
        <div className="flex flex-col items-center gap-3">
          <div
            className="w-16 h-16 rounded-2xl flex items-center justify-center"
            style={{
              backgroundColor: success
                ? 'color-mix(in srgb, var(--c-accent) 20%, transparent)'
                : 'color-mix(in srgb, var(--c-surface-alt) 80%, transparent)',
              border: '1px solid var(--c-border)',
              transition: 'background-color 0.3s ease',
            }}
          >
            {success
              ? <ShieldCheck size={32} style={{ color: 'var(--c-accent)' }} />
              : <Lock size={32} style={{ color: 'var(--c-text-2)' }} />
            }
          </div>
          <div className="text-center">
            <h2
              className="text-lg font-bold tracking-tight"
              style={{ color: 'var(--c-text-1)' }}
            >
              Admin Authentication
            </h2>
            <p className="text-sm mt-1" style={{ color: 'var(--c-text-2)' }}>
              กรอกรหัส PIN 4 หลักเพื่อเข้าใช้งาน
            </p>
          </div>
        </div>

        {/* PIN Fields */}
        <div className={`flex gap-3 ${shake ? 'shake' : ''} ${success ? 'pin-success' : ''}`}>
          {digits.map((digit, idx) => (
            <input
              key={idx}
              ref={refs[idx]}
              type="password"
              inputMode="numeric"
              maxLength={1}
              value={digit}
              className="pin-input"
              style={{
                borderColor: success
                  ? 'var(--c-accent)'
                  : digit
                    ? 'color-mix(in srgb, var(--c-accent) 60%, var(--c-border))'
                    : 'var(--c-border)',
              }}
              onChange={(e) => handleChange(idx, e.target.value)}
              onKeyDown={(e) => handleKeyDown(idx, e)}
              onPaste={handlePaste}
              disabled={success}
              autoComplete="off"
            />
          ))}
        </div>

        {/* Error Message */}
        <div className="h-5 flex items-center justify-center">
          {error && (
            <p
              className="text-sm font-medium"
              style={{ color: '#ef4444', animation: 'fadeIn 0.2s ease' }}
            >
              {error}
            </p>
          )}
          {success && (
            <p
              className="text-sm font-medium"
              style={{ color: 'var(--c-accent)', animation: 'fadeIn 0.2s ease' }}
            >
              ✓ เข้าสู่ระบบสำเร็จ
            </p>
          )}
        </div>

        {/* Hint */}
        <p className="text-xs text-center" style={{ color: 'var(--c-text-2)', opacity: 0.5 }}>
          กรอกรหัส PIN อัตโนมัติเมื่อพิมพ์ครบ 4 หลัก
        </p>
      </div>
    </div>
  )
}
</file>

<file path="src/features/admin-config/AdminSettings.jsx">
import { useState, useEffect, useCallback } from 'react'
import { Plus, Pencil, Trash2, Save, X, Download, Upload, Settings, Calendar, FileSpreadsheet } from 'lucide-react'
import {
  loadKpiConfig, saveKpiConfig, loadDefaultKpiConfig,
  loadBranchData, saveBranchData, loadHistoryLog, appendHistory,
  parseExcelFile, mapExcelToBranchData, extractPeriodFromFilename,
} from '../../data/transformer'
import AdminPinGate from './AdminPinGate'

const EMPTY_KPI = {
  kpi_id: '',
  kpi_name: '',
  unit: 'ราย',
  weight: 1.0,
  max_score: 5,
  category: '',
  display_size: 'small',
  thresholds: { score_1: 80, score_2: 85, score_3: 90, score_4: 95, score_5: 100 },
}

export default function AdminSettings() {
  // ─── PIN Gate ───
  const [authenticated, setAuthenticated] = useState(
    () => sessionStorage.getItem('admin_auth') === '1'
  )

  const handleAuthenticated = useCallback(() => {
    sessionStorage.setItem('admin_auth', '1')
    setAuthenticated(true)
  }, [])

  // ─── KPI Config State ───
  const [kpiConfig, setKpiConfig] = useState([])
  const [modalOpen, setModalOpen] = useState(false)
  const [editingKpi, setEditingKpi] = useState(null)
  const [form, setForm] = useState({ ...EMPTY_KPI })
  const [saveMsg, setSaveMsg] = useState(null)

  // ─── Upload State ───
  const [branchData, setBranchData] = useState([])
  const [uploading, setUploading] = useState(false)
  const [uploadMsg, setUploadMsg] = useState(null)
  const [selectedPeriod, setSelectedPeriod] = useState('')
  const [periodLabel, setPeriodLabel] = useState('')
  const [historyLog, setHistoryLog] = useState([])

  useEffect(() => {
    if (!authenticated) return
    ;(async () => {
      let config = loadKpiConfig()
      if (!config) config = await loadDefaultKpiConfig()
      setKpiConfig(config)

      const data = loadBranchData() || []
      setBranchData(data)
      setHistoryLog(loadHistoryLog())
    })()
  }, [authenticated])

  // ─── Upload Handler ───
  const handleUpload = useCallback(async (e) => {
    const file = e.target.files?.[0]
    if (!file) return

    setUploading(true)
    setUploadMsg(null)

    try {
      const rows = await parseExcelFile(file)
      const mapped = mapExcelToBranchData(rows, kpiConfig)
      saveBranchData(mapped)
      setBranchData(mapped)

      let period = selectedPeriod
      let label = periodLabel

      if (!period) {
        const extracted = extractPeriodFromFilename(file.name)
        if (extracted) {
          period = extracted.period
          label = extracted.label
        }
      }

      if (period && label) {
        const log = appendHistory(period, label, mapped, kpiConfig)
        setHistoryLog(log)
      }

      setUploadMsg({ type: 'success', text: `อัปโหลดสำเร็จ: ${mapped.length} สาขา` })
    } catch (err) {
      setUploadMsg({ type: 'error', text: err.message })
    } finally {
      setUploading(false)
      e.target.value = ''
    }
  }, [kpiConfig, selectedPeriod, periodLabel])

  // ─── KPI CRUD ───
  const openAdd = () => {
    const nextNum = kpiConfig.length + 1
    setForm({ ...EMPTY_KPI, kpi_id: `kpi_${String(nextNum).padStart(2, '0')}` })
    setEditingKpi(null)
    setModalOpen(true)
  }

  const openEdit = (kpi) => {
    setForm({ ...kpi, thresholds: { ...kpi.thresholds } })
    setEditingKpi(kpi.kpi_id)
    setModalOpen(true)
  }

  const handleDelete = (kpiId) => {
    if (!confirm(`ลบ KPI "${kpiId}" ?`)) return
    const updated = kpiConfig.filter((k) => k.kpi_id !== kpiId)
    setKpiConfig(updated)
    saveKpiConfig(updated)
    flash('ลบเรียบร้อย')
  }

  const handleSave = () => {
    if (!form.kpi_id || !form.kpi_name) {
      alert('กรุณากรอก ID และ ชื่อ KPI')
      return
    }

    let updated
    if (editingKpi) {
      updated = kpiConfig.map((k) => (k.kpi_id === editingKpi ? { ...form } : k))
    } else {
      if (kpiConfig.find((k) => k.kpi_id === form.kpi_id)) {
        alert(`KPI ID "${form.kpi_id}" ซ้ำ`)
        return
      }
      updated = [...kpiConfig, { ...form }]
    }

    setKpiConfig(updated)
    saveKpiConfig(updated)
    setModalOpen(false)
    flash(editingKpi ? 'แก้ไขเรียบร้อย' : 'เพิ่มเรียบร้อย')
  }

  const handleExport = () => {
    const blob = new Blob([JSON.stringify(kpiConfig, null, 2)], { type: 'application/json' })
    const url = URL.createObjectURL(blob)
    const a = document.createElement('a')
    a.href = url
    a.download = 'kpi-config.json'
    a.click()
    URL.revokeObjectURL(url)
  }

  const handleImport = (e) => {
    const file = e.target.files?.[0]
    if (!file) return
    const reader = new FileReader()
    reader.onload = (ev) => {
      try {
        const data = JSON.parse(ev.target.result)
        if (Array.isArray(data)) {
          setKpiConfig(data)
          saveKpiConfig(data)
          flash(`นำเข้า ${data.length} KPI สำเร็จ`)
        }
      } catch {
        alert('ไฟล์ JSON ไม่ถูกต้อง')
      }
    }
    reader.readAsText(file)
    e.target.value = ''
  }

  const handleReset = async () => {
    if (!confirm('รีเซ็ตค่า KPI ทั้งหมดกลับเป็นค่าเริ่มต้น?')) return
    const config = await loadDefaultKpiConfig()
    setKpiConfig(config)
    flash('รีเซ็ตเรียบร้อย')
  }

  const flash = (msg) => {
    setSaveMsg(msg)
    setTimeout(() => setSaveMsg(null), 2500)
  }

  const updateField = (field, value) => setForm((prev) => ({ ...prev, [field]: value }))
  const updateThreshold = (key, value) =>
    setForm((prev) => ({ ...prev, thresholds: { ...prev.thresholds, [key]: parseFloat(value) || 0 } }))

  // ─── PIN Gate Screen ───
  if (!authenticated) {
    return <AdminPinGate onSuccess={handleAuthenticated} />
  }

  return (
    <div className="space-y-6">

      {/* ────── Upload Section (ย้ายมาจากหน้าแรก) ────── */}
      <div className="card p-4">
        <div className="flex items-center gap-2 mb-3">
          <FileSpreadsheet size={16} style={{ color: 'var(--c-accent)' }} />
          <h2 className="text-sm font-bold" style={{ color: 'var(--c-text-1)' }}>
            อัปโหลดข้อมูล Excel
          </h2>
        </div>
        <div className="flex flex-wrap items-center gap-4">
          <div className="flex items-center gap-2">
            <Calendar size={16} style={{ color: 'var(--c-text-2)' }} />
            <select
              className="input-field text-sm w-auto"
              value={selectedPeriod}
              onChange={(e) => {
                setSelectedPeriod(e.target.value)
                if (e.target.value) {
                  const [y, m] = e.target.value.split('-')
                  const thaiMonths = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.']
                  const thaiYear = parseInt(y) > 2500 ? y : parseInt(y) + 543
                  setPeriodLabel(`${thaiMonths[parseInt(m) - 1]} ${thaiYear}`)
                }
              }}
            >
              <option value="">เลือกงวด (หรือตั้งชื่อไฟล์ Data_YYYY_MM)</option>
              {Array.from({ length: 12 }, (_, i) => {
                const m = String(i + 1).padStart(2, '0')
                const thaiMonths = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.']
                return (
                  <option key={m} value={`2569-${m}`}>
                    {thaiMonths[i]} 2569
                  </option>
                )
              })}
            </select>
          </div>

          <label className="btn-primary flex items-center gap-2 text-sm cursor-pointer">
            <Upload size={16} />
            {uploading ? 'กำลังอัปโหลด...' : 'อัปโหลด Excel'}
            <input
              type="file"
              accept=".xlsx,.xls,.csv"
              className="hidden"
              onChange={handleUpload}
              disabled={uploading}
            />
          </label>

          {uploadMsg && (
            <span className={`text-sm font-medium ${uploadMsg.type === 'success' ? 'num-positive' : 'num-negative'}`}>
              {uploadMsg.text}
            </span>
          )}

          <span className="text-xs ml-auto" style={{ color: 'var(--c-text-2)' }}>
            <FileSpreadsheet size={14} className="inline mr-1" />
            {branchData.length} สาขา | {kpiConfig.length} KPI
          </span>
        </div>
      </div>

      {/* ────── KPI Config Header ────── */}
      <div className="flex items-center justify-between flex-wrap gap-3">
        <div className="flex items-center gap-3">
          <Settings size={20} style={{ color: 'var(--c-accent)' }} />
          <h1 className="text-lg font-bold" style={{ color: 'var(--c-text-1)' }}>
            จัดการ KPI
          </h1>
          {saveMsg && (
            <span className="text-sm font-medium num-positive" style={{ animation: 'fadeIn 0.2s ease' }}>
              {saveMsg}
            </span>
          )}
        </div>
        <div className="flex items-center gap-2">
          <button className="btn-primary flex items-center gap-1.5 text-sm" onClick={openAdd}>
            <Plus size={14} /> เพิ่ม KPI
          </button>
          <button className="btn-secondary flex items-center gap-1.5 text-sm" onClick={handleExport}>
            <Download size={14} /> ส่งออก
          </button>
          <label className="btn-secondary flex items-center gap-1.5 text-sm cursor-pointer">
            <Upload size={14} /> นำเข้า
            <input type="file" accept=".json" className="hidden" onChange={handleImport} />
          </label>
          <button className="btn-secondary text-sm" onClick={handleReset}>
            รีเซ็ต
          </button>
        </div>
      </div>

      {/* ────── KPI Master List ────── */}
      <div className="card overflow-hidden">
        <div className="overflow-x-auto">
          <table className="data-table">
            <thead>
              <tr>
                <th className="text-center w-16">ID</th>
                <th className="text-left">ชื่อ KPI</th>
                <th className="text-center">หน่วย</th>
                <th className="text-center">หมวด</th>
                <th className="text-center">น้ำหนัก</th>
                <th className="text-center">คะแนนเต็ม</th>
                <th className="text-center">ขนาดการ์ด</th>
                <th className="text-center">เกณฑ์ 1</th>
                <th className="text-center">เกณฑ์ 2</th>
                <th className="text-center">เกณฑ์ 3</th>
                <th className="text-center">เกณฑ์ 4</th>
                <th className="text-center">เกณฑ์ 5</th>
                <th className="text-center w-24">จัดการ</th>
              </tr>
            </thead>
            <tbody>
              {kpiConfig.map((kpi) => (
                <tr key={kpi.kpi_id}>
                  <td className="text-center font-mono font-bold" style={{ color: 'var(--c-accent)' }}>
                    {kpi.kpi_id.replace('kpi_', '')}
                  </td>
                  <td className="text-left font-medium" style={{ color: 'var(--c-text-1)' }}>
                    {kpi.kpi_name}
                  </td>
                  <td className="text-center">{kpi.unit}</td>
                  <td className="text-center">{kpi.category}</td>
                  <td className="text-center font-mono">{kpi.weight}</td>
                  <td className="text-center font-mono">{kpi.max_score}</td>
                  <td className="text-center">
                    <span
                      className="text-xs px-2 py-0.5 rounded"
                      style={{
                        backgroundColor: kpi.display_size === 'large' ? 'var(--c-accent)' : 'var(--c-surface-alt)',
                        color: kpi.display_size === 'large' ? '#fff' : 'var(--c-text-2)',
                      }}
                    >
                      {kpi.display_size === 'large' ? 'ใหญ่' : 'เล็ก'}
                    </span>
                  </td>
                  <td className="text-center font-mono">{kpi.thresholds.score_1}%</td>
                  <td className="text-center font-mono">{kpi.thresholds.score_2}%</td>
                  <td className="text-center font-mono">{kpi.thresholds.score_3}%</td>
                  <td className="text-center font-mono">{kpi.thresholds.score_4}%</td>
                  <td className="text-center font-mono">{kpi.thresholds.score_5}%</td>
                  <td className="text-center">
                    <div className="flex justify-center gap-1">
                      <button
                        onClick={() => openEdit(kpi)}
                        className="p-1.5 rounded transition-colors"
                        style={{ color: 'var(--c-accent)' }}
                        title="แก้ไข"
                      >
                        <Pencil size={14} />
                      </button>
                      <button
                        onClick={() => handleDelete(kpi.kpi_id)}
                        className="p-1.5 rounded transition-colors"
                        style={{ color: '#EF4444' }}
                        title="ลบ"
                      >
                        <Trash2 size={14} />
                      </button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      {/* ────── Add/Edit Modal ────── */}
      {modalOpen && (
        <div className="modal-overlay" onClick={() => setModalOpen(false)}>
          <div className="modal-content" onClick={(e) => e.stopPropagation()}>
            <div className="flex items-center justify-between mb-4">
              <h2 className="text-base font-bold" style={{ color: 'var(--c-text-1)' }}>
                {editingKpi ? `แก้ไข KPI: ${editingKpi}` : 'เพิ่ม KPI ใหม่'}
              </h2>
              <button onClick={() => setModalOpen(false)} style={{ color: 'var(--c-text-2)' }}>
                <X size={20} />
              </button>
            </div>

            <div className="space-y-4">
              {/* Row 1: ID + Name */}
              <div className="grid grid-cols-3 gap-3">
                <div>
                  <label className="text-xs font-medium mb-1 block" style={{ color: 'var(--c-text-2)' }}>
                    KPI ID
                  </label>
                  <input
                    className="input-field text-sm"
                    value={form.kpi_id}
                    onChange={(e) => updateField('kpi_id', e.target.value)}
                    disabled={!!editingKpi}
                    placeholder="kpi_01"
                  />
                </div>
                <div className="col-span-2">
                  <label className="text-xs font-medium mb-1 block" style={{ color: 'var(--c-text-2)' }}>
                    ชื่อ KPI
                  </label>
                  <input
                    className="input-field text-sm"
                    value={form.kpi_name}
                    onChange={(e) => updateField('kpi_name', e.target.value)}
                    placeholder="ชื่อตัวชี้วัด"
                  />
                </div>
              </div>

              {/* Row 2: Unit, Category, Weight, Max Score, Size */}
              <div className="grid grid-cols-5 gap-3">
                <div>
                  <label className="text-xs font-medium mb-1 block" style={{ color: 'var(--c-text-2)' }}>หน่วย</label>
                  <input className="input-field text-sm" value={form.unit} onChange={(e) => updateField('unit', e.target.value)} placeholder="ราย" />
                </div>
                <div>
                  <label className="text-xs font-medium mb-1 block" style={{ color: 'var(--c-text-2)' }}>หมวด</label>
                  <input className="input-field text-sm" value={form.category} onChange={(e) => updateField('category', e.target.value)} placeholder="สินเชื่อ" />
                </div>
                <div>
                  <label className="text-xs font-medium mb-1 block" style={{ color: 'var(--c-text-2)' }}>น้ำหนัก</label>
                  <input type="number" step="0.1" className="input-field text-sm" value={form.weight} onChange={(e) => updateField('weight', parseFloat(e.target.value) || 0)} />
                </div>
                <div>
                  <label className="text-xs font-medium mb-1 block" style={{ color: 'var(--c-text-2)' }}>คะแนนเต็ม</label>
                  <input type="number" className="input-field text-sm" value={form.max_score} onChange={(e) => updateField('max_score', parseInt(e.target.value) || 5)} />
                </div>
                <div>
                  <label className="text-xs font-medium mb-1 block" style={{ color: 'var(--c-text-2)' }}>ขนาดการ์ด</label>
                  <select className="input-field text-sm" value={form.display_size} onChange={(e) => updateField('display_size', e.target.value)}>
                    <option value="small">เล็ก</option>
                    <option value="large">ใหญ่ (รายเดือน)</option>
                  </select>
                </div>
              </div>

              {/* Row 3: Thresholds */}
              <div>
                <label className="text-xs font-medium mb-2 block" style={{ color: 'var(--c-text-2)' }}>
                  เกณฑ์คะแนน (% ของเป้าหมาย)
                </label>
                <div className="grid grid-cols-5 gap-3">
                  {[1, 2, 3, 4, 5].map((n) => (
                    <div key={n}>
                      <label className="text-xs mb-1 block text-center" style={{ color: getScoreColor(n), fontWeight: 600 }}>
                        คะแนน {n}
                      </label>
                      <input
                        type="number"
                        className="input-field text-sm text-center"
                        value={form.thresholds[`score_${n}`]}
                        onChange={(e) => updateThreshold(`score_${n}`, e.target.value)}
                      />
                    </div>
                  ))}
                </div>
              </div>

              {/* Actions */}
              <div className="flex justify-end gap-2 pt-2">
                <button className="btn-secondary text-sm" onClick={() => setModalOpen(false)}>ยกเลิก</button>
                <button className="btn-primary flex items-center gap-1.5 text-sm" onClick={handleSave}>
                  <Save size={14} />
                  {editingKpi ? 'บันทึกการแก้ไข' : 'เพิ่ม KPI'}
                </button>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  )
}

function getScoreColor(level) {
  const colors = { 1: '#EF4444', 2: '#F97316', 3: '#F59E0B', 4: '#22C55E', 5: '#10B981' }
  return colors[level] || '#6B7280'
}
